# Neo4j 连接配置
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=你的安全密码_请修改

# LLM 配置
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=你的 API 密钥_请修改
LLM_MODEL=gpt-4
LLM_EMBEDDING_MODEL=text-embedding-3-small

# 实体提取器：simple | llm | hybrid
ENTITY_EXTRACTOR=llm

# 向量嵌入
STORE_EMBEDDING=false
RECALL_USE_EMBEDDING=false

# API 密钥（用于 Web API 认证）
MINIMEM_API_KEY=你的 API 密钥_请修改

# Grafana 管理员密码
GRAFANA_ADMIN_PASSWORD=你的 Grafana 密码_请修改

# 记忆批量写入配置
MEMORY_BATCH_ENABLED=true
MEMORY_BATCH_TURNS=10
MEMORY_BATCH_KEEP_PAIRS=5

# 自动备份配置
MEMORY_AUTO_BACKUP_ENABLED=true
MEMORY_AUTO_BACKUP_INTERVAL_HOURS=6
MEMORY_AUTO_BACKUP_KEEP_DAYS=7

# 空闲触发配置（秒）
MEMORY_IDLE_FLUSH_SECONDS=180
